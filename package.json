{
  "name": "portfolio-react",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run server:dev\"",
    "dev:client": "vite",
    "dev:share": "concurrently \"npm run dev:client:share\" \"npm run server:dev\"",
    "dev:client:share": "vite --host 0.0.0.0 --port 5173",
    "build": "vite build",
    "preview": "vite preview",
    "server": "cd server && node server.js",
    "server:dev": "node scripts/free-port.cjs 3001 && npm --prefix server run dev",
    "start": "concurrently \"npm run dev:client\" \"npm run server\"",
    "install:all": "npm install && cd server && npm install"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "react-icons": "^4.12.0",
    "axios": "^1.6.2",
    "framer-motion": "^10.16.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.0.0",
    "concurrently": "^8.2.2"
  }
}
